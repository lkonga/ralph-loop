{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2022",
		"outDir": "out",
		"rootDir": ".",
		"lib": ["ES2022"],
		"types": ["node"],
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true
	},
	"include": ["src/**/*.ts", "cli/**/*.ts"],
	"exclude": ["node_modules", "out"]
}
